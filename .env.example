# StudentToolHub Environment Configuration
# Copy this file to .env.local for local development (don't commit .env.local)

# ─────────────────────────────────────────────────────────────────
# GOOGLE ADSENSE CONFIGURATION
# ─────────────────────────────────────────────────────────────────
# Get your Publisher ID from: https://adsense.google.com
# Replace ca-pub-XXXXXXXXXXXXXXXX with your actual ID
VITE_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX

# Ad Slot IDs - Get these from your AdSense account
# https://adsense.google.com/adsettings/adunits
VITE_BANNER_AD_SLOT=1234567890
VITE_DISPLAY_AD_SLOT=0987654321
VITE_VIDEO_AD_SLOT=5566778899

# Enable/Disable ads globally
VITE_ADS_ENABLED=false

# ─────────────────────────────────────────────────────────────────
# GOOGLE ANALYTICS 4 (GA4)
# ─────────────────────────────────────────────────────────────────
# Get Measurement ID from: https://analytics.google.com
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GA_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────
# FORMSPREE (FOR CONTACT FORM)
# ─────────────────────────────────────────────────────────────────
# Create a form at: https://formspree.io
# Replace with your actual Form ID
VITE_FORMSPREE_ID=YOUR_FORM_ID

# ─────────────────────────────────────────────────────────────────
# SITE CONFIGURATION
# ─────────────────────────────────────────────────────────────────
VITE_SITE_URL=https://studenttoolhub.com
VITE_SITE_NAME=StudentToolHub
VITE_SITE_DESCRIPTION=81+ free online tools for students and engineers

# ─────────────────────────────────────────────────────────────────
# DEVELOPMENT/PRODUCTION FLAGS
# ─────────────────────────────────────────────────────────────────
VITE_ENV=development
