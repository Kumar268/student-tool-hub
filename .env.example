# ─────────────────────────────────
# StudentToolHub Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────

# Google AdSense
# Set to true ONLY after AdSense approval
VITE_ADS_ENABLED=false
VITE_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX

# Google Analytics 4
# Get your ID from analytics.google.com
VITE_GA_ID=G-XXXXXXXXXX

# Site URL (used for sitemap + SEO canonical URLs)
VITE_SITE_URL=https://your-domain.vercel.app
