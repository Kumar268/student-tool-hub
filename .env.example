# ─────────────────────────────────
# StudentToolHub Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────

# Google AdSense
# Set to true ONLY after AdSense approval
VITE_ADS_ENABLED=false
VITE_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX

# Google Analytics 4 (GA4)
# ✅ Setup Instructions:
#    1. Go to https://analytics.google.com
#    2. Click "Admin" → "Create Property" → Select your website
#    3. Go to "Data Streams" → "Web" → Copy your "Measurement ID"
#    4. Format: G-XXXXXXXXXX (starts with 'G-')
#
# ℹ️  If not set or left as placeholder (XXXX), GA will be disabled
# ℹ️  Respects user cookie consent (CookieConsent.jsx)
# ℹ️  Works across Vercel, Netlify, Docker, etc. (no custom config needed)
#
# Example values:
# VITE_GA_ID=G-A1B2C3D4E5  (production)
VITE_GA_ID=G-XXXXXXXXXX

# Site URL (used for robots.txt sitemap + SEO canonical URLs)
# CRITICAL: This value is used at build time to generate robots.txt
# Must include protocol (https://) and NO trailing slash
# Examples: https://studenttoolhub.com, https://app.example.com
VITE_SITE_URL=https://studenttoolhub.com
